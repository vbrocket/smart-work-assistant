# Database
DATABASE_URL=sqlite+aiosqlite:///./smart_assistant.db

# Ollama LLM
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Whisper Speech-to-Text
WHISPER_MODEL=base

# Azure AD / Microsoft Graph (for Outlook integration)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=common

# TTS Voices
TTS_VOICE_ARABIC=ar-SA-HamedNeural
TTS_VOICE_ENGLISH=en-US-GuyNeural

# App Settings
APP_NAME=Smart Work Assistant
DEBUG=true
