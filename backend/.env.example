# Database
DATABASE_URL=sqlite+aiosqlite:///./smart_assistant.db

# ---------- LLM / Embedding Backend ----------
# LLM provider: "ollama" (local), "huggingface" (cloud), or "openrouter" (cloud)
LLM_BACKEND=openrouter
# Embedding provider: defaults to LLM_BACKEND when empty.
EMBED_BACKEND=openrouter
# Reranker provider: defaults to EMBED_BACKEND when empty.
# "openrouter" uses the LLM for relevance scoring (no separate reranker model needed).
# "huggingface" uses bge-reranker-v2-m3 cross-encoder on HF Inference API.
RERANKER_BACKEND=openrouter

# Ollama (used when LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenRouter (used when LLM_BACKEND=openrouter)
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx
OR_LLM_MODEL=qwen/qwen3-30b-a3b-instruct-2507
OR_EMBED_MODEL=qwen/qwen3-embedding-8b

# HuggingFace Inference API (reranker + fallback LLM)
# Get your token at https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_xxxxxxxxxxxxx
HF_LLM_MODEL=MiniMaxAI/MiniMax-M2.5
HF_EMBED_MODEL=intfloat/multilingual-e5-large-instruct

# ---------- TTS Backend ----------
# "edge" (default, cloud), "xtts" (local XTTS-v2), or "namaa" (NAMAA-Saudi-TTS)
TTS_BACKEND=edge

# XTTS-v2 (used when TTS_BACKEND=xtts)
XTTS_SPEAKER_WAV_AR=voices/male_ar.wav
XTTS_SPEAKER_WAV_EN=voices/male_en.wav
XTTS_DEVICE=cuda

# Whisper Speech-to-Text
WHISPER_MODEL=medium

# Azure AD / Microsoft Graph (for Outlook integration)
# Get these from Azure Portal: https://portal.azure.com
AZURE_CLIENT_ID=
AZURE_TENANT_ID=consumers

# TTS Voices (used by Edge TTS)
TTS_VOICE_ARABIC=ar-SA-HamedNeural
TTS_VOICE_ENGLISH=en-US-GuyNeural

# App Settings
APP_NAME=Smart Work Assistant
DEBUG=true
