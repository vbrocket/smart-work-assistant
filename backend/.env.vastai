# ==========================================================================
# .env.vastai — Vast.ai GPU server (all local models via vLLM)
# ==========================================================================
# Copy this to .env:  cp .env.vastai .env

# Database
DATABASE_URL=sqlite+aiosqlite:///./smart_assistant.db

# ---------- LLM / Embedding / Reranker Backend ----------
LLM_BACKEND=vllm
EMBED_BACKEND=vllm
RERANKER_BACKEND=vllm

# vLLM local servers (started by deploy-vastai.sh)
VLLM_LLM_URL=http://localhost:8001/v1
VLLM_LLM_MODEL=Qwen/Qwen3.5-27B
VLLM_EMBED_URL=http://localhost:8002/v1
VLLM_EMBED_MODEL=BAAI/bge-m3
VLLM_RERANK_URL=http://localhost:8003
VLLM_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Router uses the same main LLM (no separate router service)
VLLM_ROUTER_URL=http://localhost:8001/v1
VLLM_ROUTER_MODEL=Qwen/Qwen3.5-27B

# Thinking / reasoning budget (tokens allocated for model's internal reasoning)
THINKING_BUDGET=512

# ---------- STT (Speech-to-Text) ----------
# Local Whisper on GPU — fast and free
STT_BACKEND=whisper
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda:0
WHISPER_COMPUTE_TYPE=float16

# ---------- TTS Backend ----------
TTS_BACKEND=elevenlabs

# ElevenLabs (used when TTS_BACKEND=elevenlabs)
ELEVENLABS_API_KEY=sk_94eba7588e8fa01b023e9810ba5997013935c4d763b283fd
ELEVENLABS_VOICE_ID=t9akNmCDhz230CEXOYmn
ELEVENLABS_MODEL=eleven_multilingual_v2

# TTS Voices (used by Edge TTS fallback)
TTS_VOICE_ARABIC=ar-SA-HamedNeural
TTS_VOICE_ENGLISH=en-US-GuyNeural

# Azure AD / Microsoft Graph (for Outlook integration)
AZURE_CLIENT_ID=206a17c1-3d37-461b-b70c-1f36170c1365
AZURE_TENANT_ID=consumers

# App Settings
APP_NAME=Smart Work Assistant
DEBUG=true
