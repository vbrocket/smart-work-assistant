# ==========================================================================
# .env.cloud — Cloud APIs (OpenRouter + HuggingFace + Gemini STT)
# ==========================================================================
# Copy this to .env:  cp .env.cloud .env

# Database
DATABASE_URL=sqlite+aiosqlite:///./smart_assistant.db

# ---------- LLM / Embedding / Reranker Backend ----------
LLM_BACKEND=openrouter
EMBED_BACKEND=openrouter
RERANKER_BACKEND=openrouter

# Ollama (used when LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OR_LLM_MODEL=qwen/qwen3-30b-a3b-instruct-2507
OR_EMBED_MODEL=qwen/qwen3-embedding-8b

# HuggingFace Inference API (fallback)
HF_API_TOKEN=hf_REPLACE_ME
HF_LLM_MODEL=MiniMaxAI/MiniMax-M2.5
HF_EMBED_MODEL=intfloat/multilingual-e5-large-instruct

# ---------- STT (Speech-to-Text) ----------
# Gemini 2.5 Pro via OpenRouter (cloud)
STT_BACKEND=openrouter
OR_STT_MODEL=google/gemini-2.5-pro
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ---------- TTS Backend ----------
TTS_BACKEND=xtts
XTTS_SPEAKER_WAV_AR=voices/male_ar.wav
XTTS_SPEAKER_WAV_EN=voices/male_en.wav
XTTS_DEVICE=cuda

# TTS Voices (used by Edge TTS)
TTS_VOICE_ARABIC=ar-SA-HamedNeural
TTS_VOICE_ENGLISH=en-US-GuyNeural

# Azure AD / Microsoft Graph
AZURE_CLIENT_ID=206a17c1-3d37-461b-b70c-1f36170c1365
AZURE_TENANT_ID=consumers

# App Settings
APP_NAME=Smart Work Assistant
DEBUG=true
